# Next.js dev env template. Copy to `client/.env.local` (gitignored) and edit.
#
# Next.js 는 빌드/실행 시점에 `NEXT_PUBLIC_*` 변수만 클라이언트 번들로 노출한다.
# 값 변경 후에는 반드시 `npm run dev` 재시작 필요 (hot-reload 안 됨).

# Backend API base URL.
# - 로컬 백엔드: http://localhost:8000
# - Pongchi 서버: https://backend.pongchi.kro.kr  (TLS 적용됨)
# - 미설정 시 client/lib/api.ts 의 기본값(localhost:8000) 적용
# 참고: 원격 호스트에 http 를 넣어도 api.ts 의 normalizeApiBaseUrl 이 https 로 승격한다.
NEXT_PUBLIC_API_BASE_URL=https://backend.pongchi.kro.kr
