# JWT
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/emotion_music

# Spotify Web API — Client Credentials Flow
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# CORS — comma-separated allowlist. Empty/unset → dev defaults (localhost:3000, 127.0.0.1:3000)
# Production example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=
