# JWT
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/emotion_music

# STT — Whisper 어댑터 패턴 (ADR-0002)
# STT_PROVIDER=api   → OpenAI Whisper API (기본값, 클라우드 비용 발생)
# STT_PROVIDER=local → faster-whisper 로컬 모델 (비용 0, GPU/CPU 부담)
STT_PROVIDER=api

# OpenAI — Whisper API 백엔드용 (STT_PROVIDER=api 일 때 필요)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# 로컬 Whisper 모델 크기 (STT_PROVIDER=local 일 때 사용, 기본: small)
# tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small

# Gemini — ContextAnalyzer LLM (ADR-0002: gemini-2.0-flash-lite)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# 모델 ID는 GA 전환 시 ADR 없이 여기서만 변경
GEMINI_MODEL=gemini-2.0-flash-lite

# Spotify Web API — Client Credentials Flow
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# CORS — comma-separated allowlist. Empty/unset → dev defaults (localhost:3000, 127.0.0.1:3000)
# Production example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=
