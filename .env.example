# Production `.env` template for docker-compose.prod.yml
#
# 배치 위치: 배포 서버의 docker-compose.prod.yml 옆 (예: /opt/se_project/SE-final-project/.env)
# .gitignore 처리되어 있으므로 이 파일은 절대 커밋 금지. 본 .env.example 만 템플릿으로 유지.
#
# CI/CD 흐름: GitHub Actions 가 SCP 로 compose 파일만 갱신하고 `.env` 는 건드리지 않는다.
# 따라서 키가 변경되면 서버에서 수동으로 .env 갱신 → docker compose up -d 재시작 필요.

# ── JWT (필수) ───────────────────────────────────────────────────────────────
# 32+ 바이트 랜덤 시크릿. 운영 키가 노출되면 즉시 회전.
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (필수) ──────────────────────────────────────────────────────────
# docker-compose 내부 네트워크에서 host 는 서비스명 'db'.
DATABASE_URL=postgresql://postgres:postgres@db:5432/se_project

# Postgres 컨테이너 초기화 (db 서비스 환경변수에서 사용)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=se_project

# ── Spotify Web API (선택, /spotify 라우트 사용 시 필수) ──────────────────────
# https://developer.spotify.com/dashboard 에서 발급
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── CORS (필수) ──────────────────────────────────────────────────────────────
# 콤마 분리 허용 origin. 비워두면 dev 기본값(localhost:3000, 127.0.0.1:3000) 사용.
# 운영에서는 client 의 실제 origin 을 명시 (Electron 빌드 검증 후 추가).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── ML 서비스 (필수) ──────────────────────────────────────────────────────────
# Docker 컨테이너 내부에서 호스트 nginx 를 통해 ML 서버로 라우팅.
# 호스트 nginx: dev.ml.pongchi.kro.kr → 192.168.0.3:8001 (RTX 2070 데스크탑)
# Docker 내부에서는 gateway IP 로 호스트 nginx 에 접근.
# 개발 시 팀원 노트북: ML_SERVICE_URL=http://dev.ml.pongchi.kro.kr
ML_SERVICE_URL=http://172.20.0.1:8001
